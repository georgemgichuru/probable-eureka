# Copy to .env and adjust. Never commit the real .env.
# docker-compose reads this file automatically.

# --- Django ---------------------------------------------------------------
# Compose interpolates $VAR in this file, so keep "$" out of values (or escape it as "$$").
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
# Comma-separated
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins allowed to call the API from the browser
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# --- Postgres -------------------------------------------------------------
POSTGRES_DB=probable_eureka
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Consumed by Django. In compose, host is the service name "db".
DATABASE_URL=postgres://postgres:postgres@db:5432/probable_eureka

# --- Redis ----------------------------------------------------------------
# In compose, host is the service name "redis".
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Frontend (dev) -------------------------------------------------------
# Where the Vite dev server proxies /api to (compose sets this to the backend service).
VITE_API_PROXY_TARGET=http://backend:8000
